NODE_ENV=development

# Telegram (from @BotFather)
TELEGRAM_BOT_TOKEN=

# PostgreSQL (see docker-compose.yml for local defaults)
DATABASE_URL=postgresql://diary:diary@localhost:5432/diary?schema=public

# OpenAI (Whisper + structured extraction)
OPENAI_API_KEY=
# AmneziaVPN: there is no localhost HTTP proxy to configure. If split tunnel sends only selected sites via VPN,
# ensure OpenAI (api.openai.com) is included, or use full-tunnel mode — otherwise Node cannot reach OpenAI.
# Ready-to-import IPv4 list (chatgpt.com portal, covers OpenAI): data/amnezia-openai-chatgpt.ip-list.json — see data/AMNEZIA-IMPORT.txt
# Refresh list: npm run amnezia:iplist
# For Clash/V2RayN etc. that expose a local HTTP proxy, set one of:
# OPENAI_HTTPS_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY / HTTP_PROXY
# Optional chat model for profile extraction (default: gpt-4o-mini)
OPENAI_CHAT_MODEL=gpt-4o-mini

# HTTP health probe
HEALTH_PORT=3000
