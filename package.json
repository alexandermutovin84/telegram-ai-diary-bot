{
  "name": "telegram-ai-diary-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram AI diary bot — backend infrastructure",
  "type": "module",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "check-openai": "tsx scripts/check-openai.ts",
    "check-whisper": "tsx scripts/check-whisper.ts",
    "amnezia:iplist": "tsx scripts/fetch-amnezia-openai-iplist.ts",
    "repair:profiles": "tsx scripts/repair-profiles.ts",
    "deploy:vps": "bash scripts/deploy-remote.sh",
    "deploy:railway": "railway up",
    "railway:provision": "node scripts/railway-provision.mjs",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "dotenv": "^16.5.0",
    "https-proxy-agent": "^7.0.6",
    "openai": "^4.104.0",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/node": "^22.15.21",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "prettier": "^3.5.3",
    "prisma": "^6.8.2",
    "@railway/cli": "^4.59.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1"
  }
}
