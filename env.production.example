# VPS: cp env.production.example .env
# Railway: задайте переменные в dashboard (см. DEPLOY-RAILWAY.md)

NODE_ENV=production

# Telegram (@BotFather)
TELEGRAM_BOT_TOKEN=

# Postgres (must match POSTGRES_* below)
POSTGRES_USER=diary
POSTGRES_PASSWORD=change-me-long-random-password
POSTGRES_DB=diary
DATABASE_URL=postgresql://diary:change-me-long-random-password@postgres:5432/diary?schema=public

# OpenAI (often works from EU/US VPS without VPN)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_HTTPS_PROXY=http://proxy:port

HEALTH_PORT=3000
